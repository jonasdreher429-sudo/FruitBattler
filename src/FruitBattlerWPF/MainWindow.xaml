<!-- Prompt: create for WPF for my Game fruit battler a good looking Main window. only use the .xaml so
    no stuff thats created in the back code. it should have 3 Buttons pls dont add any events just the looks. on the buttons should stay Start, 
    TeamBuilder and Exit. Pls add good looking stuff that has a nice grassy vibe -->

<!-- Start -->

<Window x:Class="FruitBattlerWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fruit Battler"
        Height="720"
        Width="1280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E3B1E">

    <Window.Resources>

        <!-- Main Grass Button Style -->
        <Style x:Key="GrassButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="260"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Margin" Value="0,12"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="#C8FF8C"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#7ED957" Offset="0"/>
                        <GradientStop Color="#3F8F2B" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="22"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Background="{TemplateBinding Background}">

                            <Grid>

                                <!-- Shine -->
                                <Border Height="18"
                                        VerticalAlignment="Top"
                                        Margin="8"
                                        CornerRadius="12"
                                        Opacity="0.25">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="White" Offset="0"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>

                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#F2FFBE"/>
                            </Trigger>

                            <!-- Pressed -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>

                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- Background -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#87D86D" Offset="0"/>
                <GradientStop Color="#3D7A32" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Decorative Background Circles -->
        <Ellipse Width="450"
                 Height="450"
                 Fill="#44FFFFFF"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-120,-120,0,0"/>

        <Ellipse Width="300"
                 Height="300"
                 Fill="#22FFFFFF"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-80,-80"/>

        <!-- Grass Hills -->
        <Ellipse Height="220"
                 VerticalAlignment="Bottom"
                 Fill="#2F6A24"
                 Margin="-150,0,-150,-120"/>

        <Ellipse Height="180"
                 VerticalAlignment="Bottom"
                 Fill="#3E8A2F"
                 Margin="-50,0,-50,-90"/>

        <!-- Main Content -->
        <Grid>

            <!-- Title -->
            <StackPanel VerticalAlignment="Top"
                        Margin="0,70,0,0">

                <TextBlock Text="FRUIT"
                           FontSize="64"
                           FontWeight="Black"
                           Foreground="#F7FFB2"
                           HorizontalAlignment="Center"
                           FontFamily="Verdana"/>

                <TextBlock Text="BATTLER"
                           FontSize="88"
                           FontWeight="Black"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,-10,0,0"
                           FontFamily="Verdana"/>

                <!-- Glow -->
                <TextBlock Text="BATTLER"
                           FontSize="88"
                           FontWeight="Black"
                           Foreground="#55FFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,-103,0,0"
                           FontFamily="Verdana"/>
            </StackPanel>

            <!-- Menu Panel -->
            <Border Width="420"
                    Height="340"
                    CornerRadius="30"
                    Background="#66000000"
                    BorderBrush="#99FFFFFF"
                    BorderThickness="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,120,0,0">

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">

                    <Button x:Name="ButtonStart" Content="Start"
                            Style="{StaticResource GrassButtonStyle}" Click="ButtonStart_Click"/>

                    <Button x:Name="ButtonTeamBuilder" Content="TeamBuilder"
                            Style="{StaticResource GrassButtonStyle}" Click="ButtonTeamBuilder_Click"/>

                    <Button x:Name="ButtonExit" Content="Exit"
                            Style="{StaticResource GrassButtonStyle}" Click="ButtonExit_Click"/>

                </StackPanel>
            </Border>

            <!-- Bottom Decoration -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,30">

                <Ellipse Width="14" Height="14" Fill="#D6FF8A" Margin="6"/>
                <Ellipse Width="10" Height="10" Fill="#B7F26C" Margin="6"/>
                <Ellipse Width="14" Height="14" Fill="#D6FF8A" Margin="6"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
<!-- Ende -->
