<Window x:Class="FruitBattlerWPF.Pages_window.TeamBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FruitBattlerWPF.Pages_window"
        xmlns:uc="clr-namespace:FruitBattlerWPF.UserControls" 
        mc:Ignorable="d"
        Title="Fruit Battler - Team Builder" Height="750" Width="950"
        WindowStartupLocation="CenterScreen" Background="#F4F9F4">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#2ECC71"/>
        <SolidColorBrush x:Key="LightGreenBg" Color="#E8F5E9"/>
        <SolidColorBrush x:Key="DarkGreenText" Color="#1E4620"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#A3E4D7"/>
        <SolidColorBrush x:Key="DeleteRed" Color="#E74C3C"/>

        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryGreen}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#27AE60"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DeleteRed}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ExitButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#7F8C8D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#95A5A6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FruitNameStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DarkGreenText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="TEAM BUILDER" 
                       FontSize="30" 
                       FontWeight="Black" 
                       Foreground="{StaticResource DarkGreenText}"/>
            <TextBlock Text="Wähle deine Früchte aus und erstelle dein Kampf-Team!" 
                       FontSize="14" 
                       Foreground="#7F8C8D" 
                       Margin="0,5,0,0"/>
            <Separator Background="{StaticResource PrimaryGreen}" Margin="0,12,0,0" Height="2"/>
        </StackPanel>
        <Button x:Name="BtnSave" Content="Save" Style="{StaticResource ExitButtonStyle}" HorizontalAlignment="Right" Cursor="Hand" Margin="0,12,164,33" Width="123" Click="BtnSave_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
        </Button>

        <Button x:Name="BtnLoad" Content="Load" Click="BtnLoad_Click" Margin="756,12,10,33">
            <Button.Resources>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Button.Resources>
            <Button.Style>
                <StaticResource ResourceKey="ModernButtonStyle"/>
            </Button.Style>
        </Button>

        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="15" 
                Padding="15"
                BorderBrush="{StaticResource AccentGreen}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="270" ShadowDepth="2" Opacity="0.05"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <WrapPanel x:Name="FruitPanel" HorizontalAlignment="Center" ItemWidth="190" ItemHeight="230">

                    <Border x:Name="Border_PyronanaUserControl" MouseLeftButtonDown="Border_PyronanaUserControl_MouseLeftButtonDown" Margin="10" CornerRadius="10" Background="{StaticResource LightGreenBg}" BorderThickness="1" BorderBrush="#C8E6C9" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="75" Height="75">
                                <uc:PyronanaUserControl x:Name="UcPyronana">
                                    <uc:PyronanaUserControl.LayoutTransform>
                                        <TranslateTransform X="20" Y="18"/>
                                    </uc:PyronanaUserControl.LayoutTransform>
                                </uc:PyronanaUserControl>
                            </Grid>
                            <TextBlock Text="Pyronana" Style="{StaticResource FruitNameStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Border_AquabeereUserControl" MouseLeftButtonDown="Border_AquabeereUserControl_MouseLeftButtonDown" Margin="10" CornerRadius="10" Background="{StaticResource LightGreenBg}" BorderThickness="1" BorderBrush="#C8E6C9" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="75" Height="75">
                                <uc:AquabeereUserControl x:Name="UcAquabeere">
                                    <uc:AquabeereUserControl.LayoutTransform>
                                        <TranslateTransform X="20" Y="18"/>
                                    </uc:AquabeereUserControl.LayoutTransform>
                                </uc:AquabeereUserControl>
                            </Grid>
                            <TextBlock Text="Aquabeere" Style="{StaticResource FruitNameStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Border_VoltimetteUserControl" MouseLeftButtonDown="Border_VoltimetteUserControl_MouseLeftButtonDown" Margin="10" CornerRadius="10" Background="{StaticResource LightGreenBg}" BorderThickness="1" BorderBrush="#C8E6C9" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="75" Height="75">
                                <uc:VoltimetteUserControl x:Name="UcVoltimette">
                                    <uc:VoltimetteUserControl.LayoutTransform>
                                        <TranslateTransform X="20" Y="18"/>
                                    </uc:VoltimetteUserControl.LayoutTransform>
                                </uc:VoltimetteUserControl>
                            </Grid>
                            <TextBlock Text="Voltimette" Style="{StaticResource FruitNameStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Border_FlorapfelUserControl" MouseLeftButtonDown="Border_FlorapfelUserControl_MouseLeftButtonDown" Margin="10" CornerRadius="10" Background="{StaticResource LightGreenBg}" BorderThickness="1" BorderBrush="#C8E6C9" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="75" Height="75">
                                <uc:FlorapfelUserControl x:Name="UcFlorapfel">
                                    <uc:FlorapfelUserControl.LayoutTransform>
                                        <TranslateTransform X="20" Y="18"/>
                                    </uc:FlorapfelUserControl.LayoutTransform>
                                </uc:FlorapfelUserControl>
                            </Grid>
                            <TextBlock Text="Florapfel" Style="{StaticResource FruitNameStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Border_FrostubeUserControl" MouseLeftButtonDown="Border_FrostubeUserControl_MouseLeftButtonDown" Margin="10" CornerRadius="10" Background="{StaticResource LightGreenBg}" BorderThickness="1" BorderBrush="#C8E6C9" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="75" Height="75">
                                <uc:FrostubeUserControl x:Name="UcFrostube">
                                    <uc:FrostubeUserControl.LayoutTransform>
                                        <TranslateTransform X="20" Y="18"/>
                                    </uc:FrostubeUserControl.LayoutTransform>
                                </uc:FrostubeUserControl>
                            </Grid>
                            <TextBlock Text="Frostube" Style="{StaticResource FruitNameStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Border_TerrangoUserControl" MouseLeftButtonDown="Border_TerrangoUserControl_MouseLeftButtonDown" Margin="10" CornerRadius="10" Background="{StaticResource LightGreenBg}" BorderThickness="1" BorderBrush="#C8E6C9" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="75" Height="75">
                                <uc:TerrangoUserControl x:Name="UcTerrango">
                                    <uc:TerrangoUserControl.LayoutTransform>
                                        <TranslateTransform X="20" Y="18"/>
                                    </uc:TerrangoUserControl.LayoutTransform>
                                </uc:TerrangoUserControl>
                            </Grid>
                            <TextBlock Text="Terrango" Style="{StaticResource FruitNameStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Border_WindpfirsichUserControl" MouseLeftButtonDown="Border_WindpfirsichUserControl_MouseLeftButtonDown" Margin="10" CornerRadius="10" Background="{StaticResource LightGreenBg}" BorderThickness="1" BorderBrush="#C8E6C9" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="75" Height="75">
                                <uc:WindpfirsichUserControl x:Name="UcWindpfirsich">
                                    <uc:WindpfirsichUserControl.LayoutTransform>
                                        <TranslateTransform X="20" Y="18"/>
                                    </uc:WindpfirsichUserControl.LayoutTransform>
                                </uc:WindpfirsichUserControl>
                            </Grid>
                            <TextBlock Text="Windpfirsich" Style="{StaticResource FruitNameStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Border_MystikokosUserControl" MouseLeftButtonDown="Border_MystikokosUserControl_MouseLeftButtonDown" Margin="10" CornerRadius="10" Background="{StaticResource LightGreenBg}" BorderThickness="1" BorderBrush="#C8E6C9" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="75" Height="75">
                                <uc:MystikokosUserControl x:Name="UcMystikokos">
                                    <uc:MystikokosUserControl.LayoutTransform>
                                        <TranslateTransform X="20" Y="18"/>
                                    </uc:MystikokosUserControl.LayoutTransform>
                                </uc:MystikokosUserControl>
                            </Grid>
                            <TextBlock Text="Mystikokos" Style="{StaticResource FruitNameStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Border_ToxibirneUserControl" MouseLeftButtonDown="Border_ToxibirneUserControl_MouseLeftButtonDown" Margin="10" CornerRadius="10" Background="{StaticResource LightGreenBg}" BorderThickness="1" BorderBrush="#C8E6C9" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="75" Height="75">
                                <uc:ToxibirneUserControl x:Name="UcToxibirne">
                                    <uc:ToxibirneUserControl.LayoutTransform>
                                        <TranslateTransform X="20" Y="18"/>
                                    </uc:ToxibirneUserControl.LayoutTransform>
                                </uc:ToxibirneUserControl>
                            </Grid>
                            <TextBlock Text="Toxibirne" Style="{StaticResource FruitNameStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Border_KnacknussUserControl" MouseLeftButtonDown="Border_KnacknussUserControl_MouseLeftButtonDown" Margin="10" CornerRadius="10" Background="{StaticResource LightGreenBg}" BorderThickness="1" BorderBrush="#C8E6C9" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="75" Height="75">
                                <uc:KnacknussUserControl x:Name="UcKnacknuss">
                                    <uc:KnacknussUserControl.LayoutTransform>
                                        <TranslateTransform X="20" Y="18"/>
                                    </uc:KnacknussUserControl.LayoutTransform>
                                </uc:KnacknussUserControl>
                            </Grid>
                            <TextBlock Text="Knacknuss" Style="{StaticResource FruitNameStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Border_SchattenfeigeUserControl" MouseLeftButtonDown="Border_SchattenfeigeUserControl_MouseLeftButtonDown" Margin="10" CornerRadius="10" Background="{StaticResource LightGreenBg}" BorderThickness="1" BorderBrush="#C8E6C9" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="75" Height="75">
                                <uc:SchattenfeigeUserControl x:Name="UcSchattenfeige">
                                    <uc:SchattenfeigeUserControl.LayoutTransform>
                                        <TranslateTransform X="20" Y="18"/>
                                    </uc:SchattenfeigeUserControl.LayoutTransform>
                                </uc:SchattenfeigeUserControl>
                            </Grid>
                            <TextBlock Text="Schattenfeige" Style="{StaticResource FruitNameStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Broder_GlanzkirscheUserControl" MouseLeftButtonDown="Broder_GlanzkirscheUserControl_MouseLeftButtonDown" Margin="10" CornerRadius="10" Background="{StaticResource LightGreenBg}" BorderThickness="1" BorderBrush="#C8E6C9" Cursor="Hand">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="75" Height="75">
                                <uc:GlanzkirscheUserControl x:Name="UcGlanzkirsche">
                                    <uc:GlanzkirscheUserControl.LayoutTransform>
                                        <TranslateTransform X="20" Y="18"/>
                                    </uc:GlanzkirscheUserControl.LayoutTransform>
                                </uc:GlanzkirscheUserControl>
                            </Grid>
                            <TextBlock Text="Glanzkirsche" Style="{StaticResource FruitNameStyle}"/>
                        </StackPanel>
                    </Border>

                </WrapPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="BtnHinzufuegen" Content="Hinzufügen" Style="{StaticResource ModernButtonStyle}" Margin="0,0,15,0" Click="BtnHinzufuegen_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="BtnLoeschen" Content="Löschen" Style="{StaticResource DeleteButtonStyle}" Click="BtnLoeschen_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <TextBlock Text=""              
                           Name="TextBlockTeam"
                           FontSize="20" 
                           FontWeight="Black" 
                           Margin="20,0,20,0"
                           Foreground="{StaticResource DarkGreenText}"
                           VerticalAlignment="Center"/>
            </StackPanel>


            <Button x:Name="BtnBeenden" Content="Exit" Style="{StaticResource ExitButtonStyle}" HorizontalAlignment="Right" Click="BtnBeenden_Click" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>