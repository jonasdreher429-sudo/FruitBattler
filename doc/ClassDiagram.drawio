  <diagram name="Seite-1" id="Ts93ZBJaMBF27M6H52ml">
    <mxGraphModel dx="1369" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntop to bottom direction\nskinparam classAttributeIconSize 0\nskinparam shadowing false\nskinparam roundcorner 8\n\nskinparam class {\n    BackgroundColor #f8f8f8\n    BorderColor #444444\n    ArrowColor #444444\n}\n\n&#39; =========================\n&#39; ENUM\n&#39; =========================\n\nenum FruitType {\n    Feuer\n    Wasser\n    Elektro\n    Pflanze\n    Eis\n    Erde\n    Flug\n    Psycho\n    Gift\n    Gestein\n    Unlicht\n    Licht\n}\n\n&#39; =========================\n&#39; CLASSES\n&#39; =========================\n\nclass GameHandler {\n    + int RoundCount\n    + int CurrentDungerPlayer\n    + int CurrentDungerEnemy\n    + FruitTeam PlayerTeam\n    + FruitTeam EnemyTeam\n    + Fruit CurrentPlayerFruit\n    + Fruit CurrentEnemyFruit\n    + bool IsGameOver\n\n    --\n    + StartGame()\n    + NextRound()\n    + CalculateDamage() : int\n    + ApplyMove()\n    + HandleFaint()\n    + SwitchFruit()\n    + GetNextDungerValue() : int\n    + CheckWinCondition() : bool\n    + EndGame()\n}\n\nclass GameVisualizer {\n    + Canvas GameCanvas\n    + Window CurrentWindow\n\n    --\n    + DrawBattleScene()\n    + UpdateHPBars()\n    + PlayAttackAnimation()\n    + ShowDamageText()\n    + UpdateDungerUI()\n    + SwitchMenuView()\n    + RefreshScreen()\n}\n\nclass EnemyKI {\n    + FruitTeam EnemyTeam\n\n    --\n    + ChooseMove() : Move\n    + ChooseSwitchFruit() : int\n    + ShouldSwitch() : bool\n}\n\nclass TeamBuilder {\n    + FruitTeam CurrentTeam\n\n    --\n    + AddFruit()\n    + RemoveFruit()\n    + ValidateTeam() : bool\n    + SaveTeam()\n    + LoadTeam()\n}\n\nclass TeamBuilderUI {\n    + List&lt;Fruit&gt; AvailableFruits\n    + TeamBuilder Builder\n\n    --\n    + DisplayFruits()\n    + AddFruitButton_Click()\n    + RemoveFruitButton_Click()\n    + SaveButton_Click()\n    + LoadButton_Click()\n    + StartGameButton_Click()\n    + UpdateTeamDisplay()\n}\n\nclass Move {\n    + string Name\n    + FruitType Type\n    + int Damage\n    + int DungerCost\n    + string Description\n\n    --\n    + UseMove()\n}\n\nclass Fruit {\n    + string Name\n    + FruitType Type\n    + int MaxHP\n    + int CurrentHP\n    + int Attack\n    + int Defense\n    + int Speed\n    + bool IsAlive\n    + Move[] MoveSet\n    + UserControl FruitControl\n\n    --\n    + ReceiveDamage()\n    + Heal()\n    + AttackTarget()\n    + CheckAlive() : bool\n    + GetTypeMultiplier() : double\n}\n\nclass FruitTeam {\n    + Fruit[] Fruits\n    + int ActiveFruitIndex\n\n    --\n    + GetActiveFruit() : Fruit\n    + SwitchFruit()\n    + HasAliveFruit() : bool\n    + GetNextAliveFruit() : Fruit\n}\n\nclass TypeEffectiveness {\n    + Dictionary&lt;Type, double&gt; Multipliers\n\n    --\n    + GetMultiplier() : double\n}\n\nclass DungerCycle {\n    + int CurrentStep\n\n    --\n    + GetNextValue() : int\n    + Reset()\n}\n\n&#39; =========================\n&#39; RELATIONSHIPS\n&#39; =========================\n\nGameHandler --&gt; FruitTeam : PlayerTeam\nGameHandler --&gt; FruitTeam : EnemyTeam\nGameHandler --&gt; Fruit : CurrentPlayerFruit\nGameHandler --&gt; Fruit : CurrentEnemyFruit\nGameHandler --&gt; GameVisualizer\nGameHandler --&gt; EnemyKI\nGameHandler --&gt; DungerCycle\n\nGameVisualizer --&gt; GameHandler\n\nEnemyKI --&gt; FruitTeam\nEnemyKI --&gt; Move\n\nTeamBuilder --&gt; FruitTeam\n\nTeamBuilderUI --&gt; TeamBuilder\nTeamBuilderUI --&gt; Fruit\n\nFruit --&gt; Move\nFruit --&gt; FruitType\nFruit --&gt; TypeEffectiveness\n\nFruitTeam --&gt; Fruit\n\nMove --&gt; FruitType\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="M7FtRiBiaXaE9NKYyAFf-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
